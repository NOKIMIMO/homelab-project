<groups>
    <autoGenerated>
        <id/>
        <createdAt/>
        <updatedAt/>
    </autoGenerated>

    <col>
        <naming val = "index"/>
        <typing val = "int"/>
    </col>

    <!-- Titre obligatoire du chapitre/groupe -->
    <col>
        <naming val = "chapterNumber"/>
        <typing val = "String">
            <regex val = "^\d{1,5}(?:(?:\_|\.)\d{1,5})?$"/>
        </typing>
    </col>

    <!-- Relation one-to-many: Un groupe peut contenir plusieurs contenus de groupe, un contenu de groupe appartient à un seul groupe -->
    <linksTo>
        <targetObject>groupContent</targetObject>
        <cardinality>one-to-many</cardinality>
        <cascadeDelete>true</cascadeDelete>
        <cascadeUpdate>false</cascadeUpdate>
    </linksTo>

    <constraints>
        <uniqueTogether name="uq_groups_serie_index">
            <field>serie_id</field>
            <field>index</field>
        </uniqueTogether>
    </constraints>

</groups>
