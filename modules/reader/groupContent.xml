<groupContent>
    <autoGenerated>
        <id/>
        <createdAt/>
        <updatedAt/>
    </autoGenerated>

    <col>
        <naming val = "index"/>
        <typing val = "int"/>
        <unique val = "true"/>
    </col>

    <!-- Relation many-to-one: Une contenu de group est lié a une seule image, une image peut etre lié a plusieurs contenus de groupe -->
    <linksTo>
        <moduleName>photos</moduleName>
        <targetObject>photos</targetObject>
        <cardinality>many-to-one</cardinality>
        <cascadeDelete>true</cascadeDelete>
        <cascadeUpdate>false</cascadeUpdate>
    </linksTo>

        <constraints>
        <uniqueTogether name="uq_groups_content_index">
            <field>groups_id</field>
            <field>index</field>
        </uniqueTogether>
    </constraints>

</groupContent>
