{
  "name": "photo-module",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "tsx --tsconfig server/tsconfig.json server/index.ts",
    "dev:server": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "vite": "vite",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "cors": "^2.8.5",
    "exif-parser": "^0.1.12",
    "express": "^4.18.2",
    "lucide-react": "^0.300.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "daisyui": "^5.5.19",
    "http-proxy-middleware": "^2.0.6",
    "postcss": "^8.4.31",
