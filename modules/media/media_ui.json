{
  "page": {
    "id": "media_page",
    "layout": "vertical",

    "bindings": {
      "photoList": "listPhotos",
      "selectedPhoto": "getPhoto",
      "uploadPhoto": "addPhoto",
      "mediaList": "listMedia",
      "selectedMedia": "getMedia",
      "uploadMedia": "addMedia"
    },

    "state": {
      "fullscreenPhotoId": null,
      "fullscreenMediaId": null
    },

    "components": [
      {
        "type": "Header",
        "props": {
          "title": "Médiathèque"
        }
      },

      {
        "type": "Header",
        "props": {
          "title": "Photos"
        }
      },

      {
        "type": "ActionBar",
        "components": [
          {
            "type": "Button",
            "props": {
              "label": "Ajouter une photo",
              "icon": "upload",
              "uploadTarget": "photos-upload"
            }
          },
          {
            "type": "Button",
            "props": {
              "label": "Rafraîchir",
              "icon": "refresh"
            },
            "action": {
              "action": "listPhotos",
              "method": "POST"
            }
          }
        ]
      },

      {
        "type": "FileUploadZone",
        "props": {
          "id": "photos-upload",
          "accept": "image/*",
          "multiple": false
        },
        "action": [
          {
            "action": "addPhoto",
            "method": "POST"
          },
          {
            "action": "listPhotos",
            "method": "POST"
          }
        ]
      },

      {
        "type": "ElementList",
        "props": {
          "emptyMessage": "Aucune photo disponible."
        },
        "source": {
          "binding": "listPhotos",
          "method": "POST"
        },
        "preview": {
          "type": "ImageViewer",
          "source": {
            "binding": "getPhoto",
            "method": "POST"
          },
          "params": {
            "id": "{{id}}"
          },
          "props": {
            "alt": "{{file_name}}"
          }
        },
        "item": {
          "type": "ListItem",
          "props": {
            "title": "{{file_name}}"
          },
          "defaultClick": {
            "action": "getPhoto",
            "method": "POST",
            "params": {
              "id": "{{id}}"
            },
            "then": {
              "setState": {
                "selectedPhoto": "{{result}}",
                "fullscreenPhotoId": "{{id}}"
              }
            }
          },
          "actions": [
            {
              "type": "IconButton",
              "props": {
                "icon": "fullscreen",
                "tooltip": "Agrandir"
              },
              "action": {
                "action": "getPhoto",
                "method": "POST",
                "params": {
                  "id": "{{id}}"
                },
                "then": {
                  "setState": {
                    "selectedPhoto": "{{result}}",
                    "fullscreenPhotoId": "{{id}}"
                  }
                }
              }
            },
            {
              "type": "IconButton",
              "props": {
                "icon": "trash",
                "tooltip": "Supprimer"
              },
              "action": [
                {
                  "action": "deletePhoto",
                  "method": "POST",
                  "params": {
                    "id": "{{id}}"
                  }
                },
                {
                  "action": "listPhotos",
                  "method": "POST"
                }
              ]
            }
          ]
        }
      },

      {
        "type": "Modal",
        "visible": "{{fullscreenPhotoId != null}}",

        "content": {
          "type": "ImageViewer",
          "source": {
            "binding": "getPhoto",
            "method": "POST"
          },
          "params": {
            "id": "{{fullscreenPhotoId}}"
          }
        },

        "actions": [
          {
            "type": "Button",
            "props": {
              "label": "Fermer"
            },
            "action": {
              "type": "setState",
              "target": "fullscreenPhotoId",
              "value": null
            }
          }
        ]
      },

      {
        "type": "Header",
        "props": {
          "title": "Médias (audio / vidéo)"
        }
      },

      {
        "type": "ActionBar",
        "components": [
          {
            "type": "Button",
            "props": {
              "label": "Ajouter un média",
              "icon": "upload",
              "uploadTarget": "media-upload"
            }
          },
          {
            "type": "Button",
            "props": {
              "label": "Rafraîchir",
              "icon": "refresh"
            },
            "action": {
              "action": "listMedia",
              "method": "POST"
            }
          }
        ]
      },

      {
        "type": "FileUploadZone",
        "props": {
          "id": "media-upload",
          "accept": "audio/*,video/*",
          "multiple": false
        },
        "action": [
          {
            "action": "addMedia",
            "method": "POST"
          },
          {
            "action": "listMedia",
            "method": "POST"
          }
        ]
      },

      {
        "type": "ElementList",
        "props": {
          "emptyMessage": "Aucun média disponible."
        },
        "source": {
          "binding": "listMedia",
          "method": "POST"
        },
        "preview": {
          "type": "MediaPlayer",
          "source": {
            "binding": "getMedia",
            "method": "POST"
          },
          "params": {
            "id": "{{id}}"
          }
        },
        "item": {
          "type": "ListItem",
          "props": {
            "title": "{{file_name}}"
          },
          "defaultClick": {
            "action": "getMedia",
            "method": "POST",
            "params": {
              "id": "{{id}}"
            },
            "then": {
              "setState": {
                "selectedMedia": "{{result}}",
                "fullscreenMediaId": "{{id}}"
              }
            }
          },
          "actions": [
            {
              "type": "IconButton",
              "props": {
                "icon": "fullscreen",
                "tooltip": "Agrandir"
              },
              "action": {
                "action": "getMedia",
                "method": "POST",
                "params": {
                  "id": "{{id}}"
                },
                "then": {
                  "setState": {
                    "selectedMedia": "{{result}}",
                    "fullscreenMediaId": "{{id}}"
                  }
                }
              }
            },
            {
              "type": "IconButton",
              "props": {
                "icon": "trash",
                "tooltip": "Supprimer"
              },
              "action": [
                {
                  "action": "deleteMedia",
                  "method": "POST",
                  "params": {
                    "id": "{{id}}"
                  }
                },
                {
                  "action": "listMedia",
                  "method": "POST"
                }
              ]
            }
          ]
        }
      },

      {
        "type": "Modal",
        "visible": "{{fullscreenMediaId != null}}",

        "content": {
          "type": "MediaPlayer",
          "source": {
            "binding": "getMedia",
            "method": "POST"
          },
          "params": {
            "id": "{{fullscreenMediaId}}"
          },
          "props": {
            "displayViewerMode": "full",
            "autoPlay": true
          }
        },

        "actions": [
          {
            "type": "Button",
            "props": {
              "label": "Fermer"
            },
            "action": {
              "type": "setState",
              "target": "fullscreenMediaId",
              "value": null
            }
          }
        ]
      }
    ]
  }
}
