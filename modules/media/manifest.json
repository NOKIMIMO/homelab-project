{
    "id": "media",
    "name": "Médiathèque",
    "version": "1.0.0",
    "icon": "media.svg",
    "description": "Stockage et lecture de photos ainsi que de fichiers audio et vidéo.",
    "actions": [
        {
            "visual": "photos.xml",
            "functions": [
                {
                    "name": "addPhoto",
                    "description": "Ajouter une photo.",
                    "parameters": [
                        {"name": "filePath", "type": "EQUAL", "description": "Chemin du fichier photo."}
                    ],
                    "logic": [
                        {"type": "UPLOAD_FILE"}
                    ],
                    "actUponObject": "photos.xml"
                },
                {
                    "name": "getPhoto",
                    "description": "Récupérer une photo par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID de la photo à récupérer."}
                    ],
                    "logic": [
                        {"type": "GET_FILE"}
                    ],
                    "actUponObject": "photos.xml"
                },
                {
                    "name": "listPhotos",
                    "description": "Lister toutes les photos stockées.",
                    "parameters": [],
                    "logic": [
                        {"type": "LIST"}
                    ],
                    "actUponObject": "photos.xml"
                },
                {
                    "name": "getPhotoData",
                    "description": "Récupérer les données d'une photo par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID de la photo à récupérer."},
                        {"name": "file_name", "type": "EQUAL", "description": "Nom du fichier photo à récupérer."},
                        {"name": "created_at", "type": "GREATER", "description": "Date de création de la photo à récupérer."}
                    ],
                    "logic": [
                        {"type": "READ"}
                    ],
                    "actUponObject": "photos.xml"
                },
                {
                    "name": "deletePhoto",
                    "description": "Supprimer une photo par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID de la photo à supprimer."}
                    ],
                    "logic": [
                        {"type": "DELETE"}
                    ],
                    "actUponObject": "photos.xml"
                },
                {
                    "name": "addMedia",
                    "description": "Ajouter un fichier audio ou vidéo.",
                    "parameters": [
                        {"name": "filePath", "type": "EQUAL", "description": "Chemin du fichier média."}
                    ],
                    "logic": [
                        {"type": "UPLOAD_FILE"}
                    ],
                    "actUponObject": "media.xml"
                },
                {
                    "name": "getMedia",
                    "description": "Récupérer un fichier média par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID du média à récupérer."}
                    ],
                    "logic": [
                        {"type": "GET_FILE"}
                    ],
                    "actUponObject": "media.xml"
                },
                {
                    "name": "listMedia",
                    "description": "Lister tous les fichiers médias stockés.",
                    "parameters": [],
                    "logic": [
                        {"type": "LIST"}
                    ],
                    "actUponObject": "media.xml"
                },
                {
                    "name": "getMediaData",
                    "description": "Récupérer les données d'un média par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID du média à récupérer."},
                        {"name": "file_name", "type": "EQUAL", "description": "Nom du fichier média à récupérer."},
                        {"name": "created_at", "type": "GREATER", "description": "Date de création du média à récupérer."}
                    ],
                    "logic": [
                        {"type": "READ"}
                    ],
                    "actUponObject": "media.xml"
                },
                {
                    "name": "deleteMedia",
                    "description": "Supprimer un fichier média par son ID.",
                    "parameters": [
                        {"name": "id", "type": "EQUAL", "description": "ID du média à supprimer."}
                    ],
                    "logic": [
                        {"type": "DELETE"}
                    ],
                    "actUponObject": "media.xml"
                }
            ]
        }
    ],
    "uIFormat": "JSON",
    "page": "media_ui.json",
    "dataObjects": [
        "photos.xml",
        "media.xml"
    ],
    "permissions": [
        "read:media",
        "write:media",
        "delete:media"
    ]
}
