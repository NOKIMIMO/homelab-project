{
  "page": {
    "id": "photos_page",
    "layout": "vertical",

    "bindings": {
      "list": "listPhotos",
      "selectedPhoto": "getPhoto",
      "upload": "addPhoto"
    },

    "state": {
      "fullscreenPhotoId": null,
      "uploading": false
    },

    "components": [
      {
        "type": "Header",
        "props": {
          "title": "Stockage Photo"
        }
      },

      {
        "type": "ActionBar",
        "components": [
          {
            "type": "Button",
            "props": {
              "label": "Upload photo",
              "icon": "upload",
              "uploadTarget": "photos-upload"
            }
          },

          {
            "type": "Button",
            "props": {
              "label": "Refresh",
              "icon": "refresh"
            },
            "action": {
              "action": "listPhotos",
              "method": "POST"
            }
          }
        ]
      },

      {
        "type": "FileUploadZone",
        "props": {
          "id": "photos-upload",
          "accept": "image/*",
          "multiple": false
        },
        "action": [
          {
            "action": "addPhoto",
            "method": "POST"
          },
          {
            "action": "listPhotos",
            "method": "POST"
          }
        ]
      },

      {
        "type": "List",
        "props": {
          "emptyMessage": "Aucune photo disponible."
        },
        "source": {
          "binding": "listPhotos",
          "method": "POST"
        },

        "item": {
          "type": "ListItem",

          "props": {
            "title": "{{file_name}}"
          },

          "defaultClick": {
            "action": "getPhoto",
            "method": "POST",
            "params": {
              "id": "{{id}}"
            },
            "then": {
              "setState": {
                "selectedPhoto": "{{result}}",
                "fullscreenPhotoId": "{{id}}"
              }
            }
          },

          "actions": [
            {
              "type": "IconButton",
              "props": {
                "icon": "fullscreen",
                "tooltip": "Agrandir"
              },
              "action": {
                "action": "getPhoto",
                "method": "POST",
                "params": {
                  "id": "{{id}}"
                },
                "then": {
                  "setState": {
                    "selectedPhoto": "{{result}}",
                    "fullscreenPhotoId": "{{id}}"
                  }
                }
              }
            },

            {
              "type": "IconButton",
              "props": {
                "icon": "trash",
                "tooltip": "Supprimer"
              },
              "action": [
                {
                  "action": "deletePhoto",
                  "method": "POST",
                  "params": {
                    "id": "{{id}}"
                  }
                },
                {
                  "action": "listPhotos",
                  "method": "POST"
                }
              ]
            }
          ]
        }
      },

      {
        "type": "ElementList",
        "props": {
          "emptyMessage": "Aucune photo disponible."
        },
        "source": {
          "binding": "listPhotos",
          "method": "POST"
        },
        "preview": {
          "type": "ImageViewer",
          "source": {
            "binding": "getPhoto",
            "method": "POST"
          },
          "params": {
            "id": "{{id}}"
          },
          "props": {
            "alt": "{{file_name}}"
          }
        },
        "item": {
          "type": "ListItem",
          "props": {
            "title": "{{file_name}}"
          },
          "defaultClick": {
            "action": "getPhoto",
            "method": "POST",
            "params": {
              "id": "{{id}}"
            },
            "then": {
              "setState": {
                "selectedPhoto": "{{result}}",
                "fullscreenPhotoId": "{{id}}"
              }
            }
          },
          "actions": [
            {
              "type": "IconButton",
              "props": {
                "icon": "fullscreen",
                "tooltip": "Agrandir"
              },
              "action": {
                "action": "getPhoto",
                "method": "POST",
                "params": {
                  "id": "{{id}}"
                },
                "then": {
                  "setState": {
                    "selectedPhoto": "{{result}}",
                    "fullscreenPhotoId": "{{id}}"
                  }
                }
              }
            },
            {
              "type": "IconButton",
              "props": {
                "icon": "trash",
                "tooltip": "Supprimer"
              },
              "action": [
                {
                  "action": "deletePhoto",
                  "method": "POST",
                  "params": {
                    "id": "{{id}}"
                  }
                },
                {
                  "action": "listPhotos",
                  "method": "POST"
                }
              ]
            }
          ]
        }
      },

      {
        "type": "Modal",
        "visible": "{{fullscreenPhotoId != null}}",

        "content": {
          "type": "ImageViewer",
          "source": {
            "binding": "getPhoto",
            "method": "POST"
          },

          "params": {
            "id": "{{fullscreenPhotoId}}"
          }
        },

        "actions": [
          {
            "type": "Button",
            "props": {
              "label": "Fermer"
            },
            "action": {
              "type": "setState",
              "target": "fullscreenPhotoId",
              "value": null
            }
          }
        ]
      }
    ]
  }
}