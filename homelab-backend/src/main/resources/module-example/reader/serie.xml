<serie>
    <autoGenerated>
        <id/>
        <createdAt/>
        <updatedAt/>
    </autoGenerated>

    <!-- Titre obligatoire du chapitre/groupe -->
    <col>
        <naming val = "title"/>
        <typing val = "String">
            <regex val = "^.{1,255}$"/>
        </typing>
    </col>

    <!-- relation one-to-many: une série peut contenir plusieurs groupes, un groupe n'apparait que dans 1 série -->
    <linksTo>
        <targetObject>groups</targetObject>
        <cardinality>one-to-many</cardinality>
        <cascadeDelete>true</cascadeDelete>
        <cascadeUpdate>false</cascadeUpdate>
    </linksTo>

</serie>
