{
    "id": "reader",
    "name": "Liseuse Photo",
    "version": "1.0.0",
    "icon": "gallery.png",
    "description": "Visualiseur de galerie photo avec organisation par chapitres/groupes. Module de lecture uniquement - utilise le module photos pour le stockage et la récupération d'images.",
    "status": "ACTIVE",
    "type": "VISUALIZATION",
    "dependencies": [
        {
            "moduleId": "photos",
            "version": "^1.0.*"
        }
    ],
    "actions": [
        {
            "visual": "groups.xml",
            "functions": [
                {
                    "name": "createSerie",
                    "description": "Créer une nouvelle série pour regrouper des groupes.",
                    "parameters": [],
                    "logic": [
                        {
                            "type": "CREATE"
                        }
                    ],
                    "actUponObject": "serie.xml"
                },

                {
                    "name": "createGroup",
                    "description": "Créer un nouveau groupe/chapitre pour regrouper des photos.",
                    "parameters": [
                        {
                            "name": "serie_id",
                            "description": "ID de la série à laquelle le groupe appartient"
                        },
                        {
                            "name":"index",
                            "description": "Index du chapitre/groupe dans la série (permet de définir l'ordre d'affichage)"
                        }
                    ],
                    "logic": [
                        {
                            "type": "CREATE"
                        }
                    ],
                    "actUponObject": "groups.xml"
                },
                {
                    "name": "deleteGroup",
                    "description": "Supprimer un groupe/chapitre existant.",
                    "parameters": [
                        {
                            "name": "id",
                            "type": "EQUAL",
                            "description": "ID du groupe à supprimer"
                        }
                    ],
                    "logic": [
                        {
                            "type": "DELETE"
                        }
                    ],
                    "actUponObject": "groups.xml"
                },
                {
                    "name": "deleteSerie",
                    "description": "Supprimer une série existante.",
                    "parameters": [
                        {
                            "name": "id",
                            "type": "EQUAL",
                            "description": "ID de la série à supprimer (cascade groupes associés)"
                        }
                    ],
                    "logic": [
                        {
                            "type": "DELETE"
                        }
                    ],
                    "actUponObject": "serie.xml"
                },
                {
                    "name": "listGroups",
                    "description": "Lister tous les chapitres/groupes créés.",
                    "parameters": [
                        {
                            "name": "serie_id",
                            "type": "EQUAL",
                            "description": "ID de la série pour filtrer les groupes"
                        }
                    ],
                    "logic": [
                        {
                            "type": "LIST"
                        }
                    ],
                    "actUponObject": "groups.xml"
                },
                {
                    "name": "listSeries",
                    "description": "Lister toutes les séries créées.",
                    "parameters": [],
                    "logic": [
                        {
                            "type": "LIST"
                        }
                    ],
                    "actUponObject": "serie.xml"
                },
                {
                    "name": "getSerie",
                    "description": "Obtenir les détails d'une série spécifique.",
                    "parameters": [
                        {
                            "name": "id",
                            "type": "EQUAL",
                            "description": "ID de la série à obtenir (eager loading des groupes associés)"
                        }
                    ],
                    "logic": [
                        {
                            "type": "READ"
                        }
                    ],
                    "actUponObject": "serie.xml"
                },
                {
                    "name": "getGroup",
                    "description": "Obtenir les détails d'un groupe spécifique.",
                    "parameters": [
                        {
                            "name": "id",
                            "type": "EQUAL",
                            "description": "ID du groupe à obtenir (eager loading des images associées)"
                        }
                    ],
                    "logic": [
                        {
                            "type": "READ"
                        }
                    ],
                    "actUponObject": "groups.xml"
                },
                {
                    "name": "addPhotoToGroup",
                    "description": "Ajouter une photo existante à un groupe/chapitre.",
                    "parameters": [
                        {
                            "name": "id",
                            "type": "EQUAL",
                            "description": "ID du groupe auquel ajouter la photo",
                            "optional": false
                        },
                        {
                            "name": "photos_id",
                            "relation": "photos.photos.xml",
                            "type": "EQUAL",
                            "description": "ID de la photo à ajouter au groupe",
                            "optional": false
                        }
                    ],
                    "logic": [
                        {
                            "type": "CREATE"
                        }
                    ],
                    "actUponObject": "groups.xml"
                }

            ]
        }
    ],
    "page": "reader_ui.json",
    "dataObjects": [
        "groups.xml",
        "serie.xml"
    ],
    "permissions": [
        "read:reader",
        "write:reader",
        "delete:reader",
        "read:photos",
        "write:photos"
    ]
}

