<groups>
    <autoGenerated>
        <id/>
        <createdAt/>
        <updatedAt/>
    </autoGenerated>

    <col>
        <naming val = "index"/>
        <typing val = "String">
            <regex val = "^.{1,255}$"/>
        </typing>
    </col>

    <!-- Titre obligatoire du chapitre/groupe -->
    <!-- <col>
        <naming val = "title"/>
        <typing val = "String">
            <regex val = "^.{1,255}$"/>
        </typing>
    </col> -->

    <!-- Relation many-to-many: Un groupe peut contenir plusieurs photos, une photo peut être dans plusieurs groupes -->
    <linksTo>
        <moduleName>photos</moduleName>
        <targetObject>photos</targetObject>
        <cardinality>many-to-many</cardinality>
        <cascadeDelete>false</cascadeDelete>
        <cascadeUpdate>false</cascadeUpdate>
    </linksTo>

</groups>
